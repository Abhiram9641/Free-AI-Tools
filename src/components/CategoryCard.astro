---
import type { CategoryMeta } from '../data/types';

interface Props {
  meta: CategoryMeta;
  count: number;
}

const { meta, count } = Astro.props;
---

<a href={`/category/${meta.id}`} class="category-card group">
  <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl mb-3.5 relative overflow-hidden"
       style={`background: ${meta.gradient}; border: 1px solid var(--border-default);`}>
    {meta.icon}
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 55%);"></div>
  </div>
  <h3 class="text-sm font-semibold mb-1.5 leading-snug" style="color: var(--text-primary);">{meta.label}</h3>
  <p class="text-xs line-clamp-2 leading-relaxed mb-4" style="color: var(--text-tertiary);">{meta.description}</p>
  <div class="flex items-center justify-between mt-auto">
    <span class="text-xs" style="color: var(--text-muted);">{count} tools</span>
    <span class="flex items-center gap-1 text-xs font-medium group-hover:translate-x-0.5 transition-transform duration-200"
          style="color: var(--accent-primary);">
      Browse
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M2 5h6M5 2l3 3-3 3"/>
      </svg>
    </span>
  </div>
</a>
