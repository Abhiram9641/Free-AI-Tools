---
import type { Tool } from '../data/types';
import { CATEGORY_META } from '../data/types';

interface Props {
  tool: Tool;
  compact?: boolean;
}

const { tool, compact = false } = Astro.props;
const meta = CATEGORY_META[tool.category];

const pricingLabel = tool.pricing === 'free' ? 'Free' : tool.pricing === 'freemium' ? 'Freemium' : 'Paid';
const isInactive = tool.status === 'inactive';

// Pricing color tokens
const pricingStyle = tool.pricing === 'free'
  ? 'background:rgba(22,163,74,0.1);color:#16a34a;border-color:rgba(22,163,74,0.2)'
  : tool.pricing === 'freemium'
  ? 'background:var(--accent-light);color:var(--accent-primary);border-color:rgba(80,56,214,0.2)'
  : 'background:rgba(245,158,11,0.1);color:#d97706;border-color:rgba(245,158,11,0.2)';
---

<a
  href={`/tool/${tool.id}`}
  class:list={['tool-card', isInactive && 'opacity-50 pointer-events-none']}
  aria-label={tool.name}
>
  <!-- Top section -->
  <div class="flex items-start gap-3 mb-3.5">
    <!-- Category icon -->
    <div
      class="w-10 h-10 rounded-xl flex items-center justify-center text-xl shrink-0 relative overflow-hidden"
      style={`background: ${meta?.gradient ?? 'var(--bg-muted)'}; border: 1px solid var(--border-default);`}
    >
      {meta?.icon ?? '🔧'}
      <!-- Shine overlay -->
      <div class="absolute inset-0 pointer-events-none"
           style="background: linear-gradient(135deg, rgba(255,255,255,0.25) 0%, transparent 55%);"></div>
    </div>

    <!-- Name + pricing -->
    <div class="flex-1 min-w-0 pt-0.5">
      <h3 class="text-sm font-semibold leading-tight truncate mb-1"
          style="color: var(--text-primary);">
        {tool.name}
      </h3>
      <div class="flex items-center gap-1.5 flex-wrap">
        <span class="pill" style={pricingStyle}>{pricingLabel}</span>
        {tool.login_type === 'none' && (
          <span class="pill" style="font-size:10px;">No login</span>
        )}
      </div>
    </div>

    <!-- Rating -->
    {tool.rating > 0 && (
      <div class="flex items-center gap-1 shrink-0 pt-0.5">
        <svg width="11" height="11" viewBox="0 0 12 12" fill="#f59e0b">
          <path d="M6 1l1.35 2.73 3.01.44-2.18 2.12.51 3-2.69-1.41L3.31 9.3l.51-3L1.64 4.17l3.01-.44z"/>
        </svg>
        <span class="text-xs font-medium" style="color: var(--text-secondary);">{tool.rating.toFixed(1)}</span>
      </div>
    )}
  </div>

  <!-- Description -->
  <p class:list={['text-xs leading-relaxed mb-3', compact ? 'line-clamp-2' : 'line-clamp-3']}
     style="color: var(--text-tertiary);">
    {tool.description}
  </p>

  <!-- Capabilities chips -->
  {!compact && tool.capabilities.length > 0 && (
    <div class="flex flex-wrap gap-1 mb-3.5">
      {tool.capabilities.slice(0, 3).map((cap) => (
        <span class="pill" style="font-size:10px;">{cap.replace(/-/g, ' ')}</span>
      ))}
      {tool.capabilities.length > 3 && (
        <span class="text-xs" style="color: var(--text-muted);">+{tool.capabilities.length - 3}</span>
      )}
    </div>
  )}

  <!-- Footer row -->
  <div class="flex items-center justify-between pt-2.5" style="border-top: 1px solid var(--border-default);">
    {tool.models_count > 0 ? (
      <span class="text-xs" style="color: var(--text-muted);">{tool.models_count}+ models</span>
    ) : (
      <span class="text-xs" style="color: var(--text-muted);">{meta?.label}</span>
    )}
    <span class="flex items-center gap-1 text-xs font-medium transition-colors duration-200"
          style="color: var(--accent-primary);">
      Open
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M2 8L8 2M4.5 2H8v3.5"/>
      </svg>
    </span>
  </div>
</a>
