---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'FreeLM — Discover the Best Free AI Tools',
  description = 'The most comprehensive, curated directory of free AI tools — chat, image, audio, music, video, coding, and APIs. Updated June 2026.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <!-- Apply theme before render to avoid flash -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>

    <!-- ── Header ────────────────────────────────────────── -->
    <header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
      <div id="header-inner" class="transition-all duration-300">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-3">

          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 shrink-0 group" aria-label="FreeLM">
            <div class="w-7 h-7 rounded-lg flex items-center justify-center transition-transform duration-300 group-hover:scale-110"
                 style="background: var(--accent-primary); box-shadow: 0 2px 8px var(--accent-glow);">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 1.5L12 4.25V9.75L7 12.5L2 9.75V4.25L7 1.5Z" fill="white" opacity="0.95"/>
                <path d="M7 5L9.6 6.5V9.5L7 11L4.4 9.5V6.5L7 5Z" fill="white" opacity="0.35"/>
              </svg>
            </div>
            <span class="font-semibold text-sm tracking-tight" style="color: var(--text-primary);">FreeLM</span>
          </a>

          <!-- Nav links -->
          <div class="hidden md:flex items-center gap-0.5">
            <a href="/" class="nav-link" id="nav-home">Home</a>
            <a href="/explore" class="nav-link" id="nav-explore">Explore</a>
            <a href="/categories" class="nav-link" id="nav-categories">Categories</a>
          </div>

          <!-- Right actions -->
          <div class="flex items-center gap-2">
            <!-- Search trigger -->
            <button id="nav-search-trigger" aria-label="Search"
              class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm transition-all duration-200"
              style="background: var(--bg-muted); border: 1px solid var(--border-default); color: var(--text-tertiary);">
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                <circle cx="6" cy="6" r="4.5"/><path d="M10 10l2.5 2.5"/>
              </svg>
              <span class="hidden sm:inline text-xs">Search…</span>
              <kbd class="hidden sm:flex items-center text-xs px-1 py-0.5 rounded"
                   style="background: var(--bg-subtle); color: var(--text-muted); font-family: inherit;">⌘K</kbd>
            </button>

            <!-- Theme toggle -->
            <button id="theme-toggle" aria-label="Toggle theme"
              class="w-8 h-8 rounded-lg flex items-center justify-center transition-all duration-200"
              style="background: var(--bg-muted); border: 1px solid var(--border-default); color: var(--text-tertiary);">
              <!-- Sun (shown in dark mode) -->
              <svg id="icon-sun" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="hidden">
                <circle cx="8" cy="8" r="3"/>
                <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41"/>
              </svg>
              <!-- Moon (shown in light mode) -->
              <svg id="icon-moon" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M13.5 10A6 6 0 016 2.5a6 6 0 000 11 6 6 0 007.5-3.5z"/>
              </svg>
            </button>

            <!-- Mobile menu -->
            <button id="mobile-menu-btn" class="md:hidden w-8 h-8 rounded-lg flex items-center justify-center"
              style="background: var(--bg-muted); border: 1px solid var(--border-default); color: var(--text-secondary);" aria-label="Menu">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M2 4h12M2 8h12M2 12h12"/>
              </svg>
            </button>
          </div>
        </nav>
      </div>

      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="hidden md:hidden border-t"
           style="background: var(--bg-overlay); border-color: var(--border-default); backdrop-filter: blur(16px);">
        <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
          <a href="/" class="nav-link-mobile">Home</a>
          <a href="/explore" class="nav-link-mobile">Explore</a>
          <a href="/categories" class="nav-link-mobile">Categories</a>
        </div>
      </div>
    </header>

    <!-- ── Search Modal ───────────────────────────────────── -->
    <div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true">
      <div id="search-backdrop" class="absolute inset-0 backdrop-enter"
           style="background: rgba(0,0,0,0.35); backdrop-filter: blur(4px);"></div>
      <div class="relative flex items-start justify-center pt-[12vh] px-4">
        <div class="w-full max-w-xl modal-enter">
          <div class="rounded-2xl overflow-hidden"
               style="background: var(--bg-surface); border: 1px solid var(--border-strong); box-shadow: var(--shadow-modal);">
            <!-- Input row -->
            <div class="flex items-center gap-3 px-4 py-3" style="border-bottom: 1px solid var(--border-default);">
              <svg width="15" height="15" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" style="color: var(--text-muted); flex-shrink:0;">
                <circle cx="6" cy="6" r="4.5"/><path d="M10 10l2.5 2.5"/>
              </svg>
              <input id="search-input" type="text" placeholder="Search tools, models, capabilities…"
                class="flex-1 bg-transparent text-sm outline-none"
                style="color: var(--text-primary); font-family: inherit;"
                autocomplete="off" spellcheck="false" />
              <kbd class="text-xs px-1.5 py-0.5 rounded" style="background: var(--bg-muted); color: var(--text-muted);">Esc</kbd>
            </div>
            <!-- Results -->
            <div id="search-results" class="overflow-y-auto max-h-[52vh] p-2">
              <p class="text-center text-sm py-8" style="color: var(--text-muted);">Start typing to discover AI tools…</p>
            </div>
            <!-- Footer hints -->
            <div class="px-4 py-2 flex items-center gap-4 text-xs" style="border-top: 1px solid var(--border-default); color: var(--text-muted);">
              <span><kbd class="px-1 rounded" style="background:var(--bg-muted)">↑↓</kbd> navigate</span>
              <span><kbd class="px-1 rounded" style="background:var(--bg-muted)">↵</kbd> open</span>
              <span><kbd class="px-1 rounded" style="background:var(--bg-muted)">Esc</kbd> close</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Main ───────────────────────────────────────────── -->
    <main class="pt-14">
      <slot />
    </main>

    <!-- ── Footer ─────────────────────────────────────────── -->
    <footer class="mt-24" style="border-top: 1px solid var(--border-default);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
        <div class="flex flex-col md:flex-row items-start justify-between gap-8">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <div class="w-6 h-6 rounded-md flex items-center justify-center"
                   style="background: var(--accent-primary);">
                <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M7 1.5L12 4.25V9.75L7 12.5L2 9.75V4.25L7 1.5Z" fill="white" opacity="0.95"/></svg>
              </div>
              <span class="font-semibold text-sm" style="color: var(--text-primary);">FreeLM</span>
            </div>
            <p class="text-sm max-w-xs leading-relaxed" style="color: var(--text-tertiary);">
              Comprehensive directory of free AI tools, updated regularly.
            </p>
          </div>
          <div class="flex gap-12 text-sm">
            <div>
              <p class="font-medium mb-3" style="color: var(--text-secondary);">Explore</p>
              <ul class="space-y-2" style="color: var(--text-tertiary);">
                <li><a href="/explore" class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors">All Tools</a></li>
                <li><a href="/categories" class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors">Categories</a></li>
              </ul>
            </div>
            <div>
              <p class="font-medium mb-3" style="color: var(--text-secondary);">Popular</p>
              <ul class="space-y-2" style="color: var(--text-tertiary);">
                <li><a href="/category/chatting_interfaces" class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors">Chat</a></li>
                <li><a href="/category/api_providers" class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors">APIs</a></li>
                <li><a href="/category/standalone_ides" class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors">IDEs</a></li>
              </ul>
            </div>
          </div>
        </div>
        <hr class="divider my-8" />
        <p class="text-xs" style="color: var(--text-muted);">© 2026 FreeLM. Data verified June 2026. Not affiliated with any listed companies.</p>
      </div>
    </footer>

  </body>
</html>

<script>
  /* ═══════════════════════════════════════
     THEME TOGGLE
  ═══════════════════════════════════════ */
  const html = document.documentElement;
  html.classList.add('js-loaded');
  const themeBtn = document.getElementById('theme-toggle');
  const iconSun  = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');

  function syncThemeIcons() {
    const isDark = html.classList.contains('dark');
    iconSun?.classList.toggle('hidden', !isDark);
    iconMoon?.classList.toggle('hidden', isDark);
  }

  syncThemeIcons();

  themeBtn?.addEventListener('click', () => {
    html.classList.toggle('dark');
    localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
    syncThemeIcons();
    themeBtn.classList.add('theme-spin');
    setTimeout(() => themeBtn.classList.remove('theme-spin'), 400);
  });

  /* ═══════════════════════════════════════
     HEADER SCROLL EFFECT
  ═══════════════════════════════════════ */
  const headerInner = document.getElementById('header-inner');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > 16) {
      headerInner?.style.setProperty('background', 'var(--bg-overlay)');
      headerInner?.style.setProperty('backdrop-filter', 'blur(20px)');
      headerInner?.style.setProperty('-webkit-backdrop-filter', 'blur(20px)');
      headerInner?.style.setProperty('box-shadow', '0 1px 0 var(--border-default), 0 4px 16px rgba(0,0,0,0.06)');
    } else {
      headerInner?.style.removeProperty('background');
      headerInner?.style.removeProperty('backdrop-filter');
      headerInner?.style.removeProperty('-webkit-backdrop-filter');
      headerInner?.style.removeProperty('box-shadow');
    }
    lastScroll = y;
  }, { passive: true });

  /* ═══════════════════════════════════════
     ACTIVE NAV LINK
  ═══════════════════════════════════════ */
  const path = window.location.pathname;
  const navMap: Record<string, string> = {
    '/': 'nav-home',
    '/explore': 'nav-explore',
    '/categories': 'nav-categories',
    '/free-claude-codex': 'nav-codex',
  };
  const activeId = navMap[path] ?? (path.startsWith('/category') ? 'nav-categories' : path.startsWith('/explore') ? 'nav-explore' : null);
  if (activeId) document.getElementById(activeId)?.classList.add('active');

  /* ═══════════════════════════════════════
     MOBILE MENU
  ═══════════════════════════════════════ */
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  /* ═══════════════════════════════════════
     INTERSECTION OBSERVER — scroll reveal
  ═══════════════════════════════════════ */
  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const delay = el.dataset.delay ?? '0';
      setTimeout(() => {
        el.classList.remove('motion-hidden', 'motion-scale-hidden', 'motion-left-hidden');
        const type = el.dataset.motion ?? 'up';
        if (type === 'up')    el.classList.add('motion-visible');
        if (type === 'scale') el.classList.add('motion-scale-visible');
        if (type === 'left')  el.classList.add('motion-left-visible');
      }, parseInt(delay));
      io.unobserve(el);
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  // Observe anything with data-motion attribute
  document.querySelectorAll('[data-motion]').forEach(el => {
    const type = (el as HTMLElement).dataset.motion ?? 'up';
    if (type === 'up')    el.classList.add('motion-hidden');
    if (type === 'scale') el.classList.add('motion-scale-hidden');
    if (type === 'left')  el.classList.add('motion-left-hidden');
    io.observe(el);
  });

  // Stagger grid children
  document.querySelectorAll('.stagger-grid').forEach(grid => {
    Array.from(grid.children).forEach((child, i) => {
      const el = child as HTMLElement;
      el.style.animationDelay = `${i * 55}ms`;
      io.observe(el);
      el.dataset.motion = 'up';
      el.classList.add('motion-hidden');
    });
  });

  /* ═══════════════════════════════════════
     MAGNETIC CARD HOVER
  ═══════════════════════════════════════ */
  function addMagnetic(selector: string, strength = 0.25) {
    document.querySelectorAll(selector).forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = (e.clientX - cx) * strength;
        const dy = (e.clientY - cy) * strength;
        el.style.transform = `translateY(-4px) translate(${dx}px, ${dy}px)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = '';
      });
    });
  }

  // Apply magnetic after paint
  requestAnimationFrame(() => {
    addMagnetic('.tool-card', 0.06);
    addMagnetic('.category-card', 0.08);
  });

  /* ═══════════════════════════════════════
     SEARCH MODAL
  ═══════════════════════════════════════ */
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const triggers = document.querySelectorAll('#nav-search-trigger, #hero-search-btn');

  type SearchItem = {
    id: string; name: string; description: string; category: string;
    tags: string[]; capabilities: string[]; top_models: string[];
    pricing: string; notes: string; rating: number;
  };

  let fuse: null | { search: (q: string) => { item: SearchItem }[] } = null;
  let fuseLoading = false;
  let selectedIdx = -1;

  const CAT_META: Record<string, [string, string]> = {
    chatting_interfaces: ['💬', 'Chat'],
    image_generation:   ['🎨', 'Images'],
    audio_generation:   ['🎙️', 'Audio'],
    music_generation:   ['🎵', 'Music'],
    video_generation:   ['🎬', 'Video'],
    vs_code_extensions: ['🔌', 'VS Code'],
    cli_coding_agents:  ['⚡', 'CLI'],
    byok_extensions:    ['🔑', 'BYOK'],
    standalone_ides:    ['🖥️', 'IDEs'],
    api_providers:      ['🔗', 'APIs'],
  };

  function openSearch() {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => searchInput?.focus(), 50);
    if (!fuse && !fuseLoading) loadFuse();
  }

  function closeSearch() {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
    if (searchInput) searchInput.value = '';
    resetResults();
    selectedIdx = -1;
  }

  triggers.forEach(t => t.addEventListener('click', openSearch));
  backdrop?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); modal?.classList.contains('hidden') ? openSearch() : closeSearch(); }
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) closeSearch();
    if (!modal?.classList.contains('hidden')) {
      const results = document.querySelectorAll('#search-results a');
      if (e.key === 'ArrowDown') { e.preventDefault(); selectedIdx = Math.min(selectedIdx + 1, results.length - 1); highlightResult(results); }
      if (e.key === 'ArrowUp')   { e.preventDefault(); selectedIdx = Math.max(selectedIdx - 1, -1); highlightResult(results); }
      if (e.key === 'Enter' && selectedIdx >= 0) (results[selectedIdx] as HTMLAnchorElement)?.click();
    }
  });

  function highlightResult(results: NodeListOf<Element>) {
    results.forEach((r, i) => {
      (r as HTMLElement).style.background = i === selectedIdx ? 'var(--bg-muted)' : '';
    });
    (results[selectedIdx] as HTMLElement)?.scrollIntoView({ block: 'nearest' });
  }

  function resetResults() {
    const r = document.getElementById('search-results');
    if (r) r.innerHTML = '<p class="text-center text-sm py-8" style="color:var(--text-muted)">Start typing to discover AI tools…</p>';
  }

  async function loadFuse() {
    fuseLoading = true;
    try {
      const [indexRes, { default: Fuse }] = await Promise.all([
        fetch('/search-index.json'),
        import('fuse.js'),
      ]);
      const tools: SearchItem[] = await indexRes.json();
      fuse = new (Fuse as new (list: SearchItem[], opts: object) => typeof fuse)(tools, {
        keys: [
          { name: 'name',         weight: 3   },
          { name: 'description',  weight: 2   },
          { name: 'tags',         weight: 1.5 },
          { name: 'capabilities', weight: 1.5 },
          { name: 'top_models',   weight: 1   },
          { name: 'notes',        weight: 0.5 },
          { name: 'category',     weight: 0.5 },
        ],
        threshold: 0.38,
        minMatchCharLength: 2,
      });
      if (searchInput?.value.trim()) {
        renderResults(fuse!.search(searchInput.value.trim()).slice(0, 12).map(r => r.item));
      }
    } catch (e) { console.warn('Search load failed', e); }
    finally { fuseLoading = false; }
  }

  searchInput?.addEventListener('input', () => {
    selectedIdx = -1;
    const q = searchInput.value.trim();
    if (!q) { resetResults(); return; }
    if (!fuse) { const r = document.getElementById('search-results'); if (r) r.innerHTML = '<p class="text-center text-sm py-8" style="color:var(--text-muted)">Loading…</p>'; return; }
    renderResults(fuse.search(q).slice(0, 12).map(r => r.item));
  });

  function renderResults(items: SearchItem[]) {
    const c = document.getElementById('search-results');
    if (!c) return;
    if (!items.length) { c.innerHTML = '<p class="text-center text-sm py-8" style="color:var(--text-muted)">No results. Try different keywords.</p>'; return; }
    c.innerHTML = items.map(item => {
      const [icon, label] = CAT_META[item.category] ?? ['🔧', item.category];
      const freeBadge = item.pricing === 'free'
        ? `<span style="font-size:10px;padding:1px 6px;border-radius:99px;background:rgba(22,163,74,0.12);color:#16a34a;border:1px solid rgba(22,163,74,0.2)">Free</span>`
        : '';
      return `<a href="/tool/${item.id}"
        class="flex items-center gap-3 px-3 py-2 rounded-xl transition-colors"
        onclick="document.getElementById('search-modal')?.classList.add('hidden');document.body.style.overflow='';"
        onmouseenter="this.style.background='var(--bg-muted)'" onmouseleave="this.style.background=''">
        <div class="w-8 h-8 rounded-lg shrink-0 flex items-center justify-center text-base"
             style="background:var(--bg-muted);border:1px solid var(--border-default);">${icon}</div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2">
            <span style="font-size:13px;font-weight:500;color:var(--text-primary)" class="truncate">${item.name}</span>
            ${freeBadge}
          </div>
          <p style="font-size:11px;color:var(--text-muted)" class="truncate mt-0.5">${item.description}</p>
        </div>
        <span style="font-size:11px;color:var(--text-muted);flex-shrink:0">${label}</span>
      </a>`;
    }).join('');
  }
</script>

<!-- ═══════════════════════════════════════════════════════════
     MOTION + CURSOR ENGINE
     All cursor tracking, card lighting, and scroll animations
     ═══════════════════════════════════════════════════════════ -->
<script>
  /* ──────────────────────────────────────────
     Card light-tracking
     Each card gets a radial spotlight that
     follows the mouse position within it.
  ────────────────────────────────────────── */
  function bindCardLight(selector: string) {
    document.querySelectorAll<HTMLElement>(selector).forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width  * 100).toFixed(1) + '%';
        const y = ((e.clientY - rect.top)  / rect.height * 100).toFixed(1) + '%';
        card.style.setProperty('--mx', x);
        card.style.setProperty('--my', y);
      }, { passive: true });

      card.addEventListener('mouseleave', () => {
        card.style.setProperty('--mx', '50%');
        card.style.setProperty('--my', '50%');
      }, { passive: true });
    });
  }

  // Run after first paint so cards exist in DOM
  requestAnimationFrame(() => {
    bindCardLight('.tool-card');
    bindCardLight('.category-card');
  });

  // Re-bind when new cards appear (explore page filter)
  const cardObserver = new MutationObserver(() => {
    bindCardLight('.tool-card');
    bindCardLight('.category-card');
  });
  cardObserver.observe(document.body, { childList: true, subtree: true });

</script>
