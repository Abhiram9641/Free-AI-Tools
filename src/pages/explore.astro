---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import { allTools } from '../data/tools';
import { CATEGORY_META } from '../data/types';
---

<Layout
  title="Explore AI Tools — FreeLM"
  description={`Browse all ${allTools.length} free AI tools. Filter by category, pricing, capability, and more.`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-8 pb-20">
    <!-- Header -->
    <div class="mb-7" data-motion="left">
      <h1 class="text-3xl font-bold mb-1.5" style="color: var(--text-primary); letter-spacing: -0.03em;">Explore All Tools</h1>
      <p class="text-sm" style="color: var(--text-tertiary);">
        <span id="count-display">{allTools.length}</span> tools across {Object.keys(CATEGORY_META).length} categories
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-6">
      <!-- ── Sidebar ─────────────────────────────── -->
      <aside class="w-full lg:w-52 shrink-0">
        <div class="rounded-2xl p-4 sticky top-20"
             style="background: var(--bg-surface); border: 1px solid var(--border-default); box-shadow: var(--shadow-card);">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold" style="color: var(--text-primary);">Filters</h2>
            <button id="clear-filters" class="text-xs transition-colors" style="color: var(--text-muted);"
              onmouseover="this.style.color='var(--accent-primary)'" onmouseout="this.style.color='var(--text-muted)'">
              Clear all
            </button>
          </div>

          <!-- Pricing -->
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--text-muted);">Pricing</p>
            <div class="space-y-1.5">
              {['free', 'freemium', 'paid'].map(p => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="checkbox" value={p} name="pricing" class="filter-checkbox w-3.5 h-3.5 cursor-pointer accent-accent-600 rounded" />
                  <span class="text-sm capitalize" style="color: var(--text-secondary);">{p}</span>
                </label>
              ))}
            </div>
          </div>

          <hr class="divider mb-4" />

          <!-- Category -->
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--text-muted);">Category</p>
            <div class="space-y-1.5 max-h-56 overflow-y-auto no-scrollbar">
              {Object.values(CATEGORY_META).map(m => (
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" value={m.id} name="category" class="filter-checkbox w-3.5 h-3.5 cursor-pointer accent-accent-600 rounded shrink-0" />
                  <span class="text-sm flex items-center gap-1.5" style="color: var(--text-secondary);">
                    <span>{m.icon}</span>
                    {m.label}
                  </span>
                </label>
              ))}
            </div>
          </div>

          <hr class="divider mb-4" />

          <!-- Access -->
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--text-muted);">Access</p>
            <label class="flex items-center gap-2.5 cursor-pointer">
              <input type="checkbox" id="no-login-filter" class="w-3.5 h-3.5 cursor-pointer accent-accent-600 rounded" />
              <span class="text-sm" style="color: var(--text-secondary);">No login required</span>
            </label>
          </div>

          <hr class="divider mb-4" />

          <!-- Rating -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--text-muted);">Min Rating</p>
            <div class="space-y-1.5">
              {[4.5, 4, 3.5, 3].map(r => (
                <label class="flex items-center gap-2.5 cursor-pointer">
                  <input type="radio" value={String(r)} name="min-rating" class="w-3.5 h-3.5 accent-accent-600 cursor-pointer" />
                  <span class="text-sm flex items-center gap-1" style="color: var(--text-secondary);">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="#f59e0b"><path d="M6 1l1.35 2.73 3.01.44-2.18 2.12.51 3-2.69-1.41L3.31 9.3l.51-3L1.64 4.17l3.01-.44z"/></svg>
                    {r}+
                  </span>
                </label>
              ))}
            </div>
          </div>
        </div>
      </aside>

      <!-- ── Main ──────────────────────────────────── -->
      <div class="flex-1 min-w-0">
        <!-- Search + sort -->
        <div class="flex flex-col sm:flex-row gap-3 mb-5">
          <div class="relative flex-1">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" width="13" height="13"
                 viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                 style="color: var(--text-muted);">
              <circle cx="6" cy="6" r="4.5"/><path d="M10 10l2.5 2.5"/>
            </svg>
            <input id="explore-search" type="text" placeholder="Filter by name, model, or keyword…"
              class="search-input pl-9" />
          </div>
          <select id="sort-select" class="search-input w-full sm:w-44 cursor-pointer"
                  style="appearance: none; background-image: url(\"data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23888' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E\"); background-repeat: no-repeat; background-position: right 12px center; padding-right: 32px;">
            <option value="rating">Sort by Rating</option>
            <option value="name">Sort by Name</option>
          </select>
        </div>

        <!-- Active filter pills -->
        <div id="active-filters" class="flex flex-wrap gap-2 mb-4 hidden"></div>

        <!-- Grid -->
        <div id="tools-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {allTools.map((tool) => (
            <div class="tool-item"
              data-category={tool.category}
              data-pricing={tool.pricing}
              data-rating={tool.rating}
              data-login={tool.login_type}
              data-text={[tool.name, tool.description, ...(tool.tags || []), ...(tool.capabilities || []), ...(tool.top_models || []), tool.category].join(' ').toLowerCase()}>
              <ToolCard tool={tool} />
            </div>
          ))}
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden text-center py-24">
          <div class="text-5xl mb-4">🔍</div>
          <p class="font-medium mb-1" style="color: var(--text-secondary);">No tools match your filters</p>
          <p class="text-sm mb-5" style="color: var(--text-muted);">Try adjusting your search or clearing filters</p>
          <button id="empty-clear" class="btn btn-ghost text-sm">Clear filters</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const allItems = Array.from(document.querySelectorAll('.tool-item'));
  const grid = document.getElementById('tools-grid');
  const emptyState = document.getElementById('empty-state');
  const countDisplay = document.getElementById('count-display');
  const activeFiltersEl = document.getElementById('active-filters');
  const searchInput = document.getElementById('explore-search');
  const sortSelect = document.getElementById('sort-select');
  const noLoginFilter = document.getElementById('no-login-filter');
  const clearBtn = document.getElementById('clear-filters');
  const emptyClearBtn = document.getElementById('empty-clear');

  let state = { search: '', pricing: new Set(), categories: new Set(), noLogin: false, minRating: 0 };

  function applyFilters() {
    let visible = 0;
    allItems.forEach(item => {
      const d = item.dataset;
      let show = true;
      if (state.search && !d.text?.includes(state.search.toLowerCase())) show = false;
      if (state.pricing.size > 0 && !state.pricing.has(d.pricing || '')) show = false;
      if (state.categories.size > 0 && !state.categories.has(d.category || '')) show = false;
      if (state.noLogin && d.login !== 'none') show = false;
      if (parseFloat(d.rating || '0') < state.minRating) show = false;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (countDisplay) countDisplay.textContent = String(visible);
    emptyState?.classList.toggle('hidden', visible > 0);
    grid?.classList.toggle('hidden', visible === 0);
    updatePills();
  }

  function updatePills() {
    if (!activeFiltersEl) return;
    const pills = [];
    if (state.search) pills.push({ key: 'search', label: `"${state.search}"` });
    state.pricing.forEach(p => pills.push({ key: `pricing:${p}`, label: p }));
    state.categories.forEach(c => pills.push({ key: `cat:${c}`, label: c.replace(/_/g,' ') }));
    if (state.noLogin) pills.push({ key: 'noLogin', label: 'No login' });
    if (state.minRating > 0) pills.push({ key: 'rating', label: `★${state.minRating}+` });
    activeFiltersEl.classList.toggle('hidden', !pills.length);
    activeFiltersEl.innerHTML = pills.map(p => `
      <button data-key="${p.key}" class="active-pill flex items-center gap-1.5 cursor-pointer transition-all"
        style="padding:3px 10px;border-radius:99px;font-size:11px;font-weight:500;background:var(--accent-light);color:var(--accent-primary);border:1px solid rgba(80,56,214,0.2)">
        ${p.label}
        <svg width="9" height="9" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 2l6 6M8 2l-6 6"/></svg>
      </button>`).join('');
    activeFiltersEl.querySelectorAll('.active-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.key || '';
        if (key === 'search') { state.search = ''; if (searchInput) searchInput.value = ''; }
        else if (key.startsWith('pricing:')) state.pricing.delete(key.slice(8));
        else if (key.startsWith('cat:')) state.categories.delete(key.slice(4));
        else if (key === 'noLogin') { state.noLogin = false; if (noLoginFilter) noLoginFilter.checked = false; }
        else if (key === 'rating') { state.minRating = 0; document.querySelectorAll('input[name="min-rating"]').forEach(r => { r.checked = false; }); }
        applyFilters();
      });
    });
  }

  function clearAll() {
    state = { search: '', pricing: new Set(), categories: new Set(), noLogin: false, minRating: 0 };
    if (searchInput) searchInput.value = '';
    if (noLoginFilter) noLoginFilter.checked = false;
    document.querySelectorAll('.filter-checkbox,input[name="min-rating"]').forEach(el => { el.checked = false; });
    applyFilters();
  }

  searchInput?.addEventListener('input', e => { state.search = e.target.value; applyFilters(); });
  document.querySelectorAll('input[name="pricing"]').forEach(el => {
    el.addEventListener('change', e => { const t = e.target; t.checked ? state.pricing.add(t.value) : state.pricing.delete(t.value); applyFilters(); });
  });
  document.querySelectorAll('input[name="category"]').forEach(el => {
    el.addEventListener('change', e => { const t = e.target; t.checked ? state.categories.add(t.value) : state.categories.delete(t.value); applyFilters(); });
  });
  noLoginFilter?.addEventListener('change', e => { state.noLogin = e.target.checked; applyFilters(); });
  document.querySelectorAll('input[name="min-rating"]').forEach(el => {
    el.addEventListener('change', e => { state.minRating = parseFloat(e.target.value); applyFilters(); });
  });
  clearBtn?.addEventListener('click', clearAll);
  emptyClearBtn?.addEventListener('click', clearAll);
  sortSelect?.addEventListener('change', e => {
    const sort = e.target.value;
    const sorted = [...allItems].sort((a,b) =>
      sort === 'rating'
        ? parseFloat(b.dataset.rating||'0') - parseFloat(a.dataset.rating||'0')
        : (a.dataset.text||'').slice(0,50).localeCompare(b.dataset.text?.slice(0,50)||'')
    );
    sorted.forEach(el => grid?.appendChild(el));
  });
</script>
